# Local development example settings for clinical-agentic-control-plane
# Copy this file to .env.dev and replace placeholder values.

# Core runtime
CACP_ENVIRONMENT=dev
CACP_HMAC_SECRET=change-me-local-hmac
CACP_GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
LOG_LEVEL=debug

# GitHub PR target
CACP_GITHUB_TOKEN=
CACP_GITHUB_OWNER=julian-najas
CACP_GITHUB_REPO=clinic-gitops-config

# Dependencies
CACP_PG_DSN=postgresql://cacp:cacp_local@postgres:5432/cacp
CACP_REDIS_URL=redis://redis:6379/0
CACP_OPA_URL=http://opa:8181

# Optional compose override for external OPA policies
# CACP_OPA_POLICIES_PATH=../../clinic-gitops-config/environments/dev/policies/opa

# Twilio (optional)
CACP_TWILIO_ENABLED=false
CACP_TWILIO_ACCOUNT_SID=
CACP_TWILIO_AUTH_TOKEN=
CACP_TWILIO_FROM_NUMBER=

# Messaging controls
CACP_QUIET_HOURS_START=22
CACP_QUIET_HOURS_END=8
CACP_TIMEZONE=Europe/Madrid
CACP_SMS_RATE_LIMIT=3
CACP_SMS_RATE_WINDOW_SECONDS=86400
CACP_DEDUP_TTL_SECONDS=86400

# Retry policy
CACP_MAX_RETRIES=3
CACP_RETRY_BACKOFF_SECONDS=[60,300,900]
